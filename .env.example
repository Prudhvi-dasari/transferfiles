# TransferNow Clone Server Configuration

PORT=3000

# Google Firebase Configuration (100% Free - No Credit Card Needed)
# Get these credentials from Firebase Console (Project Settings -> Service Accounts -> Generate new private key)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
